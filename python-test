import requests
from bs4 import BeautifulSoup

def print_secret_message(url):
    """
    Fetches character and coordinate data from a Google Doc URL 
    and prints the resulting grid.
    """
    try:
        # 1. Fetch the document content
        response = requests.get(url)
        response.raise_for_status()
        
        # 2. Parse the HTML to find the table
        soup = BeautifulSoup(response.text, 'html.parser')
        table = soup.find('table')
        if not table:
            print("No table found in the document.")
            return

        rows = table.find_all('tr')
        
        # Dictionary to store (x, y) -> character mapping
        grid_data = {}
        max_x = 0
        max_y = 0

        # 3. Iterate through table rows (skipping the header)
        for row in rows[1:]:
            cols = row.find_all('td')
            if len(cols) < 3:
                continue
            
            # Extract data from columns
            # Expected format: [x-coordinate, Character, y-coordinate]
            try:
                x = int(cols[0].get_text().strip())
                char = cols[1].get_text().strip()
                y = int(cols[2].get_text().strip())
                
                grid_data[(x, y)] = char
                
                # Track boundaries for the grid size
                if x > max_x: max_x = x
                if y > max_y: max_y = y
            except ValueError:
                # Handle cases where non-integer data might appear in coord columns
                continue

        # 4. Print the grid
        # We loop from max_y down to 0 because y=0 is the bottom row
        for y in range(max_y, -1, -1):
            line = ""
            for x in range(max_x + 1):
                # Use a space if no character exists at this coordinate
                line += grid_data.get((x, y), " ")
            print(line)

    except Exception as e:
        print(f"An error occurred: {e}")

# Example usage:
url = "https://docs.google.com/document/d/e/2PACX-1vSvM5gDlNvt7npYHhp_XfsJvuntUhq184By5xO_pA4b_gCWeXb6dM6ZxwN8rE6S4ghUsCj2VKR21oEP/pub"
print_secret_message(url)